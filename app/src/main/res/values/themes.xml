<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme with white background -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Primary colors -->
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryDark">#3700B3</item>
        <item name="colorAccent">#03DAC5</item>
        
        <!-- Background colors - CRITICAL FOR WHITE BACKGROUND -->
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/black</item>
        <item name="android:textColorSecondary">@color/dark_gray</item>
        
        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorPrimaryDark</item>
        
        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <!-- Transparent theme ONLY for the splash/launcher activity -->
    <style name="AppTheme.Transparent" parent="AppTheme">
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:colorBackground">@android:color/transparent</item>
    </style>

    <!-- Theme for activities that should have solid background -->
    <style name="AppTheme.Solid" parent="AppTheme">
        <item name="android:windowIsTranslucent">false</item>
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorBackground">@color/white</item>
    </style>
</resources>
